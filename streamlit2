import streamlit as st
import sqlite3

conn = sqlite3.connect('database.db', check_same_thread=False)
cursor = conn.cursor()


cursor.execute(""" 
        CREATE TABLE IF NOT EXISTS tasks ( 
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            title TEXT NOT NULL,
            priority INTEGER NOT NULL
        )
    """)
conn.commit()

st.title("SQL Βάση")


conn.close()





